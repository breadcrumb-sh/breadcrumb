{
  "name": "@breadcrumb/server",
  "private": true,
  "type": "module",
  "exports": {
    "./trpc": {
      "types": "./src/api/trpc/router.ts"
    }
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "seed": "tsx scripts/seed.ts",
    "test": "vitest run",
    "eval": "evalite",
    "eval:run": "evalite run",
    "eval:ci": "evalite run --threshold=70"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.47",
    "@ai-sdk/openai": "^3.0.33",
    "@breadcrumb-sdk/ai-sdk": "^0.0.5",
    "@breadcrumb-sdk/core": "^0.0.8",
    "@clickhouse/client": "^1",
    "@hono/mcp": "^0.2.3",
    "@hono/node-server": "^1",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@polyglot-sql/sdk": "^0.2.0",
    "@trpc/server": "^11",
    "ai": "^6.0.97",
    "better-auth": "^1.4.18",
    "cron": "^4.4.0",
    "dotenv": "^16",
    "drizzle-orm": "^0.45.1",
    "hono": "^4",
    "hono-rate-limiter": "^0.4.2",
    "pg-boss": "^10.4.2",
    "pino": "^10.3.1",
    "postgres": "^3",
    "posthog-node": "^5.28.2",
    "superjson": "^2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/cron": "^2.0.1",
    "@types/node": "^22",
    "drizzle-kit": "^0.31.9",
    "evalite": "^0.19.0",
    "pino-pretty": "^13.1.3",
    "tsx": "^4",
    "typescript": "^5.7",
    "vitest": "^4.1.2"
  }
}
