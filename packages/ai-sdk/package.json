{
  "name": "@breadcrumb/ai-sdk",
  "version": "0.0.2",
  "type": "module",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
