---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Get notified - Breadcrumb">

  <!-- ── NAV ─────────────────────────────────────────────── -->
  <nav>
    <div class="page-inner h-[64px] flex items-center justify-between">
      <a href="/" class="flex items-center gap-2.5">
        <svg width="24" height="24" viewBox="0 0 278 277" fill="none">
          <path d="M198.033 0.727C240.224 -5.344 278 27.386 278 70.011c0 17.711-6.668 34.277-18 46.857v86.356c-.167-.001-.333-.003-.5-.003-40.041 0-72.5 32.459-72.5 72.5 0 .167.002.334.003.5H53c-18.778 0-34-15.222-34-34V117.955C7.062 105.25 0 88.237 0 70.011 0 27.386 37.776-5.344 79.967.727l47.639 6.854c7.557 1.088 15.231 1.088 22.788 0l47.639-6.854z" fill="currentColor"/>
        </svg>
        <span class="font-display font-semibold text-[16px] tracking-tight text-fg">Breadcrumb</span>
      </a>
      <a href="/" class="font-mono text-[11px] text-fg-3 hover:text-fg transition-colors">← back</a>
    </div>
  </nav>

  <main class="min-h-svh pb-24">
    <div class="page-inner">

      <!-- ── Panel 0: Email ──────────────────────────── -->
      <div class="step-panel active pt-12 sm:pt-16 max-w-[520px]" id="panel-0">
        <div class="font-mono text-[10px] text-fg-3 tracking-widest uppercase mb-8">
          01 / 02 - email
        </div>
        <h1 class="font-display text-[clamp(26px,4vw,36px)] font-semibold tracking-tight text-fg leading-[1.08] mb-3">
          Get notified.
        </h1>
        <p class="text-[15px] text-fg-2 leading-[1.65] mb-10">
          Drop your email and we'll reach out when breadcrumb is ready.
        </p>

        <div class="flex flex-col gap-2 mb-2">
          <label class="font-mono text-[10px] text-fg-3 tracking-widest uppercase" for="email">
            Email address
          </label>
          <div class="flex gap-[1px] border border-border bg-border">
            <input
              id="email" type="email" autocomplete="email" autofocus
              placeholder="you@company.com"
              class="flex-1 min-w-0 px-3.5 py-3 text-sm text-fg bg-white outline-none placeholder:text-fg-3 font-display"
            />
            <button
              id="email-submit"
              class="shrink-0 px-5 py-3 bg-fg text-white text-[13px] font-semibold font-display hover:opacity-80 transition-opacity whitespace-nowrap"
            >
              <span class="btn-label">Join the list →</span>
              <span class="btn-loading hidden">Saving…</span>
            </button>
          </div>
          <span id="email-error" class="hidden font-mono text-[11px] text-[#b84040]">
            Please enter a valid email address.
          </span>
        </div>
      </div>

      <!-- ── Panel 1: Tell us more ──────────────────── -->
      <div class="step-panel pt-12 sm:pt-16 max-w-[520px]" id="panel-1">
        <div class="font-mono text-[10px] text-fg-3 tracking-widest uppercase mb-8">
          02 / 02 - tell us more
        </div>
        <h1 class="font-display text-[clamp(26px,4vw,36px)] font-semibold tracking-tight text-fg leading-[1.08] mb-3">
          You're on the list.
        </h1>
        <p class="text-[15px] text-fg-2 leading-[1.65] mb-10">
          Help us build the right thing - tell us a bit about what you're working on.
        </p>

        <form id="detail-form" novalidate class="flex flex-col gap-9">

          <!-- How to run -->
          <div class="flex flex-col gap-3">
            <div class="font-mono text-[10px] text-fg-3 tracking-widest uppercase">
              How do you want to run breadcrumb?
            </div>
            <div class="grid grid-cols-3 gap-[1px] bg-border border border-border">
              {[
                { value: 'cloud', label: 'Cloud hosted',  sub: 'We handle infra'    },
                { value: 'self',  label: 'Self-hosted',   sub: 'Your own servers'   },
                { value: 'idk',   label: 'Not sure yet',  sub: "I'll figure it out" },
              ].map((o) => (
                <label class="flex flex-col gap-1.5 p-5 bg-white cursor-pointer select-none transition-colors hover:bg-surface [&:has(input:checked)]:bg-surface">
                  <input type="radio" name="deploy" value={o.value} class="sr-only" />
                  <span class="font-display text-[13px] font-semibold text-fg">{o.label}</span>
                  <span class="font-mono text-[10px] text-fg-3">{o.sub}</span>
                </label>
              ))}
            </div>
          </div>

          <!-- LLM call volume -->
          <div class="flex flex-col gap-3">
            <div class="font-mono text-[10px] text-fg-3 tracking-widest uppercase">
              LLM calls per day?
            </div>
            <div class="grid grid-cols-2 gap-[1px] bg-border border border-border">
              {[
                { value: 'proto',  label: 'Still prototyping', sub: 'Under 100'   },
                { value: 'small',  label: 'Getting traction',  sub: '100 – 10k'  },
                { value: 'medium', label: 'Scaling up',        sub: '10k – 1M'   },
                { value: 'large',  label: 'Running at scale',  sub: '1M+'        },
              ].map((o) => (
                <label class="flex flex-col gap-1.5 p-5 bg-white cursor-pointer select-none transition-colors hover:bg-surface [&:has(input:checked)]:bg-surface">
                  <input type="radio" name="scale" value={o.value} class="sr-only" />
                  <span class="font-display text-[13px] font-semibold text-fg">{o.label}</span>
                  <span class="font-mono text-[10px] text-fg-3">{o.sub}</span>
                </label>
              ))}
            </div>
          </div>

          <!-- What are you building -->
          <div class="flex flex-col gap-3">
            <div class="font-mono text-[10px] text-fg-3 tracking-widest uppercase">
              What are you building? <span class="normal-case">(optional)</span>
            </div>
            <textarea
              id="comments" name="comments" rows="4"
              placeholder="What are you working on? Anything specific you want from a tracing tool?"
              class="w-full px-4 py-3 text-sm text-fg bg-white border border-border outline-none placeholder:text-fg-3 focus:border-fg-2 resize-none transition-colors font-display"
            ></textarea>
          </div>

          <div class="flex items-center gap-2">
            <button type="submit" id="detail-submit" class="btn-primary">
              <span class="btn-label">Submit →</span>
              <span class="btn-loading hidden">Saving…</span>
            </button>
            <button type="button" id="skip-btn" class="btn-secondary">Skip</button>
            <span id="detail-error" class="hidden font-mono text-[11px] text-[#b84040] ml-1">
              Something went wrong.
            </span>
          </div>

        </form>
      </div>

      <!-- ── Panel: Success ─────────────────────────── -->
      <div class="step-panel pt-12 sm:pt-16 max-w-[520px]" id="panel-success">
        <div class="font-mono text-[10px] text-fg-3 tracking-widest uppercase mb-8">
          done
        </div>
        <h1 class="font-display text-[clamp(26px,4vw,36px)] font-semibold tracking-tight text-fg leading-[1.08] mb-3">
          That's everything.
        </h1>
        <p class="text-[15px] text-fg-2 leading-[1.65] mb-10 max-w-[400px]">
          We'll reach out when breadcrumb is ready. If something you wrote caught our attention, we might follow up sooner.
        </p>
        <a href="/" class="btn-primary">← Back to home</a>
      </div>

    </div>
  </main>
</Layout>

<style>
  .page-inner {
    max-width: 1000px;
    margin: 0 auto;
    padding-left: 1.5rem;
    padding-right: 1.5rem;
  }

  .step-panel        { display: none; animation: fadeUp 0.18s ease both; }
  .step-panel.active { display: block; }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(6px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 12px 20px;
    background: var(--color-fg);
    color: #fff;
    font-size: 13px;
    font-weight: 600;
    border: none;
    cursor: pointer;
    font-family: var(--font-display);
    transition: opacity 0.15s;
    text-decoration: none;
  }
  .btn-primary:hover { opacity: 0.82; }

  .btn-secondary {
    display: inline-flex;
    align-items: center;
    padding: 12px 16px;
    background: transparent;
    color: var(--color-fg-2);
    font-size: 13px;
    font-weight: 500;
    border: 1px solid var(--color-border);
    cursor: pointer;
    font-family: var(--font-display);
    transition: border-color 0.14s, color 0.14s;
  }
  .btn-secondary:hover { border-color: var(--color-border-strong); color: var(--color-fg); }

  #email-submit.loading .btn-label,
  #detail-submit.loading .btn-label  { display: none; }
  #email-submit.loading .btn-loading,
  #detail-submit.loading .btn-loading { display: inline !important; }
</style>

<script>
  // Pre-fill from URL param (fallback)
  const params = new URLSearchParams(window.location.search);
  const emailInput = document.getElementById('email') as HTMLInputElement;
  if (params.get('email') && emailInput) emailInput.value = params.get('email')!;

  let storedEmail = '';

  const panels = Array.from(document.querySelectorAll<HTMLElement>('.step-panel'));

  function goTo(id: string) {
    panels.forEach(p => p.classList.remove('active'));
    document.getElementById(id)?.classList.add('active');
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  // ── Step 1: email ──────────────────────────────────────────────
  const emailSubmit = document.getElementById('email-submit') as HTMLButtonElement;
  const emailError  = document.getElementById('email-error')!;

  emailSubmit.addEventListener('click', async () => {
    const email = emailInput.value.trim();
    if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
      emailError.classList.remove('hidden');
      emailInput.focus();
      return;
    }
    emailError.classList.add('hidden');
    emailSubmit.classList.add('loading');
    emailSubmit.disabled = true;

    try {
      const res = await fetch('/api/waitlist', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email }),
      });
      if (!res.ok) throw new Error();
      storedEmail = email;
      goTo('panel-1');
    } catch {
      emailSubmit.classList.remove('loading');
      emailSubmit.disabled = false;
      emailError.textContent = 'Something went wrong - please try again.';
      emailError.classList.remove('hidden');
    }
  });

  // Also submit on Enter inside the email input
  emailInput?.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') emailSubmit.click();
  });

  // ── Step 2: details ────────────────────────────────────────────
  const detailForm   = document.getElementById('detail-form') as HTMLFormElement;
  const detailSubmit = document.getElementById('detail-submit') as HTMLButtonElement;
  const detailError  = document.getElementById('detail-error')!;

  async function submitDetails() {
    detailSubmit.classList.add('loading');
    detailSubmit.disabled = true;
    detailError.classList.add('hidden');

    const deploy   = document.querySelector<HTMLInputElement>('input[name="deploy"]:checked')?.value;
    const scale    = document.querySelector<HTMLInputElement>('input[name="scale"]:checked')?.value;
    const comments = (document.getElementById('comments') as HTMLTextAreaElement)?.value.trim();

    try {
      const res = await fetch('/api/waitlist', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email: storedEmail, deploy, scale, comments }),
      });
      if (!res.ok) throw new Error();
      goTo('panel-success');
    } catch {
      detailSubmit.classList.remove('loading');
      detailSubmit.disabled = false;
      detailError.classList.remove('hidden');
    }
  }

  detailForm.addEventListener('submit', (e) => { e.preventDefault(); submitDetails(); });
  document.getElementById('skip-btn')?.addEventListener('click', () => goTo('panel-success'));
</script>
