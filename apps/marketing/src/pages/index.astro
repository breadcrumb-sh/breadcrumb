---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import dashboardImage from '../assets/dashboard.png';
---

<Layout>

  <!-- ── NAV ─────────────────────────────────────────────── -->
  <nav>
    <div class="inner h-[96px] flex items-center">
      <div class="flex items-center gap-7">
        <a href="/" class="flex items-center gap-3.5">
          <svg width="26" height="26" viewBox="0 0 584 475" fill="none">
            <path d="M347.586 0.132512C351.629 -0.38435 360.699 0.787582 366.707 0.642277C395.95 0.167608 425.194 0.0213704 454.443 0.204777C471.505 0.200603 491.006 -0.486215 507.803 1.42548C515.957 2.35401 530.956 8.83657 537.979 13.2097C559.392 26.5431 574.277 48.9316 579.956 73.2907C587.197 104.503 581.628 137.317 564.488 164.39C552.436 183.478 532.473 198.878 510.351 204.073C509.9 204.179 509.575 204.576 509.57 205.04C508.854 265.725 509.976 327.292 510.064 388.024L510.106 436.154C510.106 444.669 511.303 464.238 507.745 472.776C507.71 472.859 507.667 472.934 507.605 472.999C506.819 473.823 504.387 474.787 503.396 474.633C495.268 473.34 487.916 473.455 479.752 473.455L388.297 473.481L100.083 474.893C96.0618 474.939 93.0122 474.95 89.0805 474.642C88.8362 474.623 88.6047 474.512 88.438 474.333C83.2031 468.69 82.481 463.199 82.4292 455.787C82.3125 439.166 83.0316 422.622 83.0337 406.003L83.4946 262.393L83.5464 223.618C83.5907 218.018 84.0722 210.456 83.7719 204.979C83.7478 204.539 83.4302 204.172 83.0005 204.073C68.1725 200.657 55.5663 195.653 43.1206 186.753C20.6626 170.512 5.56415 146.025 1.13717 118.664C-3.26576 91.2668 5.41683 63.8379 21.9897 41.8171C37.8556 20.7355 64.5663 5.67801 90.5288 1.3747C104.771 0.293016 120.831 0.747659 135.077 0.80341C142.326 0.832089 178.587 -0.339907 183.308 2.34247C183.455 2.42576 183.545 2.55291 183.607 2.70966C185.066 6.40261 182.768 11.458 180.266 14.2097C174.996 20.0417 168.249 23.0493 165.783 31.0358C160.193 49.1346 174.373 69.7589 193.688 69.6628C205.679 69.6034 219.158 58.2429 220.717 46.2438C221.204 42.4985 219.316 39.326 220.679 34.7692C220.717 34.6424 220.781 34.5224 220.873 34.4265C223.1 32.0868 228.861 32.4498 231.625 33.8893C231.766 33.9628 231.884 34.0738 231.966 34.2097C233.517 36.7641 233.036 39.0757 234.001 41.5876C244.629 69.2445 275.036 79.5512 302.343 71.6413C324.986 65.0829 348.394 38.3214 343.668 13.5026C342.522 7.47271 334.833 0.701997 347.586 0.132512ZM311.109 278C309.369 278.322 308.186 278.304 307.003 279.564C306.139 281.418 306.337 283.581 306.311 285.674C293.88 303.256 293.515 280.974 284.494 280.639C277.756 280.39 282.48 291.088 284.496 294.59C302.32 322.338 326.978 278.608 311.109 278ZM269.745 242.361C266.361 240.211 263.065 240.017 259.203 240.212C254.949 240.998 253.176 241.445 249.187 243.548C246.902 247.015 246.388 248.051 245.354 252.228C247.337 261.172 251.353 269.777 261.812 270.342C271.306 268.488 276.861 259.012 274.946 249.854C274.316 246.748 272.434 244.038 269.745 242.361ZM338.088 269.841C354.729 264.118 352.708 235.085 331.055 238.673C327.137 239.89 322.006 241.699 320.479 245.731C315.748 258.233 325.428 270.21 338.088 269.841Z" fill="currentColor"/>
          </svg>
          <span class="font-display font-semibold text-[15px] tracking-tight text-fg">Breadcrumb</span>
        </a>
      </div>
    </div>
  </nav>

  <!-- ── HERO ─────────────────────────────────────────────── -->
  <section class="border-b border-border">
    <div class="inner pt-14 pb-14 sm:pt-20 sm:pb-20">
      <h1 class="font-display text-[clamp(32px,5vw,58px)] font-semibold text-fg leading-[1.04] tracking-[-0.03em] text-balance mb-5">
        Simple, self-hosted LLM observability for TypeScript
      </h1>
      <p class="text-[14px] sm:text-[15px] leading-[1.75] text-fg-2 mb-8 max-w-[430px]">
        Breadcrumb logs every prompt, completion, token count, latency, and cost. Open source and self-hostable in one click, so your data stays in your stack.
      </p>
      <div class="flex gap-3 w-full sm:w-auto">
        <a
          href="/early-access"
          class="flex-1 sm:flex-initial inline-flex items-center justify-center gap-3 px-5 py-3 bg-fg text-bg text-[13px] font-semibold font-display hover:opacity-80 transition-opacity"
        >
          Get early access <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="inline-block"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
        <a
          href="/demo"
          class="flex-1 sm:flex-initial inline-flex items-center justify-center gap-3 px-8 py-3 border border-current text-fg-2 text-[13px] font-semibold font-display hover:text-fg transition-colors"
        >
          Try demo
        </a>
      </div>
    </div>
  </section>

  <!-- ── SCREENSHOT 1: Trace timeline ──────────────────────── -->
  <section class="border-b border-border">
    <div class="inner">
      <div class="border-x border-border">
        <div class="border-b border-border flex items-center justify-between px-4 sm:px-5 py-3">
          <div class="flex items-center gap-2">
            <span class="relative flex h-[6px] w-[6px]">
              <span class="live-ping absolute inset-0 rounded-full" style="background:#22c08b;opacity:0.4"></span>
              <span class="relative rounded-full h-[6px] w-[6px]" style="background:#22c08b"></span>
            </span>
            <span class="font-mono text-[10px] text-fg-3 tracking-widest uppercase">traces - live</span>
          </div>
          <div class="flex gap-[5px]">
            <span class="block w-[6px] h-[6px]" style="background:#58508d"></span>
            <span class="block w-[6px] h-[6px]" style="background:#b4558d"></span>
            <span class="block w-[6px] h-[6px]" style="background:#e77371"></span>
            <span class="block w-[6px] h-[6px]" style="background:#7b6aad"></span>
          </div>
        </div>
        <div class="px-4 sm:px-5 pt-5 pb-6">
          <div class="flex justify-between mb-[10px]">
            <span class="font-mono text-[9px] text-fg-3 opacity-40">0</span>
            <span class="font-mono text-[9px] text-fg-3 opacity-40 hidden sm:block">250ms</span>
            <span class="font-mono text-[9px] text-fg-3 opacity-40">500ms</span>
            <span class="font-mono text-[9px] text-fg-3 opacity-40 hidden sm:block">750ms</span>
            <span class="font-mono text-[9px] text-fg-3 opacity-40">1s+</span>
          </div>
          <div class="relative">
            <div class="absolute inset-0 flex pointer-events-none" aria-hidden="true">
              <div class="w-1/4 border-r border-border h-full"></div>
              <div class="w-1/4 border-r border-border h-full"></div>
              <div class="w-1/4 border-r border-border h-full"></div>
              <div class="w-1/4 h-full"></div>
            </div>
            <div id="tl-rows" class="flex flex-col gap-[10px] sm:gap-[13px] relative"></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── TEXT ROW 1 ──────────────────────────────────────── -->
  <section class="border-b border-border">
    <div class="inner py-10 sm:py-12">
      <h2 class="font-display text-[22px] sm:text-[27px] font-semibold text-fg tracking-tight leading-snug mb-3">
        Full LLM tracing with two lines of code.
      </h2>
      <p class="text-[13px] sm:text-[14px] leading-[1.8] text-fg-2 max-w-[420px]">
        Wrap a function, name a span. That's it. Every call your app makes gets logged with its prompt, completion, tokens, latency, and cost. No agents, no config files, no SDKs with a 30-page setup guide.
      </p>
    </div>
  </section>

  <!-- ── SCREENSHOT 2: Dashboard ───────────────────────── -->
  <section class="border-b border-border">
    <div class="inner pt-8 sm:pt-12">
      <div class="browser-window">
        <div class="browser-toolbar">
          <div class="browser-dots">
            <span class="browser-dot" style="background:#ff5f57"></span>
            <span class="browser-dot" style="background:#febc2e"></span>
            <span class="browser-dot" style="background:#28c840"></span>
          </div>
          <div class="browser-address-bar">
            <span class="font-mono text-[10px] text-fg-3">app.breadcrumb.sh</span>
          </div>
          <div class="browser-dots" style="visibility:hidden">
            <span class="browser-dot"></span>
            <span class="browser-dot"></span>
            <span class="browser-dot"></span>
          </div>
        </div>
        <div class="browser-content">
          <Image src={dashboardImage} alt="Breadcrumb LLM tracing dashboard showing traces, token counts, latency, and costs" loading="lazy" format="webp" quality={80} widths={[640, 1024, 1400, 2062]} sizes="(max-width: 640px) 100vw, (max-width: 1024px) 100vw, 1000px" class="w-full block" />
        </div>
      </div>
    </div>
  </section>

  <!-- ── TEXT ROW 2 ──────────────────────────────────────── -->
  <section class="border-b border-border">
    <div class="inner py-10 sm:py-12">
      <h2 class="font-display text-[22px] sm:text-[27px] font-semibold text-fg tracking-tight leading-snug mb-3">
        Monitor every LLM call in production.
      </h2>
      <p class="text-[13px] sm:text-[14px] leading-[1.8] text-fg-2 max-w-[400px]">
        Every LLM call your app makes in production gets logged. Real prompts, real responses, real token counts. Not samples. All of them.
      </p>
    </div>
  </section>

  <!-- ── BENTO ─────────────────────────────────────────────── -->
  <section class="border-b border-border">
    <div class="inner">
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-[1px] bg-border border-x border-border">

        <!-- Cost tracking -->
        <div class="bg-surface p-6 sm:p-8 flex flex-col justify-between gap-8">
          <span class="font-mono text-[10px] text-fg-3 tracking-widest uppercase">cost per trace</span>
          <div>
            <div class="font-mono text-[40px] font-light text-fg leading-none tracking-tight mb-3">$0.0024</div>
            <p class="text-[13px] text-fg-2 leading-[1.75]">Every trace shows its token count and cost. See which calls are expensive and where your budget is actually going.</p>
          </div>
        </div>

        <!-- Open source + deploy -->
        <div class="col-span-1 sm:col-span-2 bg-surface p-6 sm:p-8 flex flex-col justify-between gap-8">
          <span class="font-mono text-[10px] text-fg-3 tracking-widest uppercase">open source</span>
          <div>
            <p class="font-display text-[17px] font-semibold text-fg leading-snug mb-2">Runs on your infra. Open source, forever.</p>
            <p class="text-[13px] text-fg-2 leading-[1.75] mb-4 max-w-[400px]">Deploy with one click on Railway or anywhere else. Your data never leaves your stack. Read the code, fork it, modify it - no usage fees, no vendor lock-in.</p>
            <a href="https://github.com/joshuaKnauber/breadcrumb" target="_blank" rel="noopener noreferrer" class="font-mono text-[10px] text-fg-3 hover:text-fg transition-colors">★ github.com/joshuaKnauber/breadcrumb</a>
          </div>
        </div>

        <!-- TypeScript + integrations -->
        <div class="col-span-1 sm:col-span-3 bg-surface p-6 sm:p-8 flex flex-col justify-between gap-8">
          <span class="font-mono text-[10px] text-fg-3 tracking-widest uppercase">typescript</span>
          <div>
            <p class="font-display text-[17px] font-semibold text-fg leading-snug mb-2">First-class TypeScript support</p>
            <p class="text-[13px] text-fg-2 leading-[1.75] max-w-[480px]">The SDK is written in TypeScript with full type coverage. One wrapper, drop it around any call and it starts logging. Works with the Vercel AI SDK out of the box, alongside OpenAI, Anthropic, and others.</p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ── FINAL CTA ───────────────────────────────────────── -->
  <section class="border-b border-border">
    <div class="inner py-12 sm:py-16">
      <h2 class="font-display text-[22px] sm:text-[28px] font-semibold text-fg tracking-tight leading-snug mb-3">
        Ready to see what's happening?
      </h2>
      <p class="text-[13px] text-fg-2 leading-[1.75] mb-7 max-w-[340px]">
        Join the waitlist. We'll reach out when it's ready.
      </p>
      <a
        href="/early-access"
        class="inline-flex items-center gap-3 px-5 py-3 bg-fg text-bg text-[13px] font-semibold font-display hover:opacity-80 transition-opacity"
      >
        Get notified <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="inline-block"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </a>
    </div>
  </section>

  <!-- ── FOOTER ─────────────────────────────────────────── -->
  <footer>
    <div class="inner py-6 flex items-center justify-between">
      <a href="/" class="flex items-center gap-2 font-display text-[13px] font-medium text-fg-3 hover:text-fg transition-colors">
        <svg width="14" height="14" viewBox="0 0 584 475" fill="none">
          <path d="M347.586 0.132512C351.629 -0.38435 360.699 0.787582 366.707 0.642277C395.95 0.167608 425.194 0.0213704 454.443 0.204777C471.505 0.200603 491.006 -0.486215 507.803 1.42548C515.957 2.35401 530.956 8.83657 537.979 13.2097C559.392 26.5431 574.277 48.9316 579.956 73.2907C587.197 104.503 581.628 137.317 564.488 164.39C552.436 183.478 532.473 198.878 510.351 204.073C509.9 204.179 509.575 204.576 509.57 205.04C508.854 265.725 509.976 327.292 510.064 388.024L510.106 436.154C510.106 444.669 511.303 464.238 507.745 472.776C507.71 472.859 507.667 472.934 507.605 472.999C506.819 473.823 504.387 474.787 503.396 474.633C495.268 473.34 487.916 473.455 479.752 473.455L388.297 473.481L100.083 474.893C96.0618 474.939 93.0122 474.95 89.0805 474.642C88.8362 474.623 88.6047 474.512 88.438 474.333C83.2031 468.69 82.481 463.199 82.4292 455.787C82.3125 439.166 83.0316 422.622 83.0337 406.003L83.4946 262.393L83.5464 223.618C83.5907 218.018 84.0722 210.456 83.7719 204.979C83.7478 204.539 83.4302 204.172 83.0005 204.073C68.1725 200.657 55.5663 195.653 43.1206 186.753C20.6626 170.512 5.56415 146.025 1.13717 118.664C-3.26576 91.2668 5.41683 63.8379 21.9897 41.8171C37.8556 20.7355 64.5663 5.67801 90.5288 1.3747C104.771 0.293016 120.831 0.747659 135.077 0.80341C142.326 0.832089 178.587 -0.339907 183.308 2.34247C183.455 2.42576 183.545 2.55291 183.607 2.70966C185.066 6.40261 182.768 11.458 180.266 14.2097C174.996 20.0417 168.249 23.0493 165.783 31.0358C160.193 49.1346 174.373 69.7589 193.688 69.6628C205.679 69.6034 219.158 58.2429 220.717 46.2438C221.204 42.4985 219.316 39.326 220.679 34.7692C220.717 34.6424 220.781 34.5224 220.873 34.4265C223.1 32.0868 228.861 32.4498 231.625 33.8893C231.766 33.9628 231.884 34.0738 231.966 34.2097C233.517 36.7641 233.036 39.0757 234.001 41.5876C244.629 69.2445 275.036 79.5512 302.343 71.6413C324.986 65.0829 348.394 38.3214 343.668 13.5026C342.522 7.47271 334.833 0.701997 347.586 0.132512ZM311.109 278C309.369 278.322 308.186 278.304 307.003 279.564C306.139 281.418 306.337 283.581 306.311 285.674C293.88 303.256 293.515 280.974 284.494 280.639C277.756 280.39 282.48 291.088 284.496 294.59C302.32 322.338 326.978 278.608 311.109 278ZM269.745 242.361C266.361 240.211 263.065 240.017 259.203 240.212C254.949 240.998 253.176 241.445 249.187 243.548C246.902 247.015 246.388 248.051 245.354 252.228C247.337 261.172 251.353 269.777 261.812 270.342C271.306 268.488 276.861 259.012 274.946 249.854C274.316 246.748 272.434 244.038 269.745 242.361ZM338.088 269.841C354.729 264.118 352.708 235.085 331.055 238.673C327.137 239.89 322.006 241.699 320.479 245.731C315.748 258.233 325.428 270.21 338.088 269.841Z" fill="currentColor"/>
        </svg>
        Breadcrumb
      </a>
      <div class="flex items-center gap-4">
        <a href="https://x.com/joshuaKnauber" target="_blank" rel="noopener noreferrer" class="text-fg-3 hover:text-fg transition-colors" aria-label="X">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor">
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.746l7.73-8.835L1.254 2.25H8.08l4.253 5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
          </svg>
        </a>
        <a href="https://github.com/joshuaKnauber/breadcrumb" target="_blank" rel="noopener noreferrer" class="text-fg-3 hover:text-fg transition-colors" aria-label="GitHub">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
