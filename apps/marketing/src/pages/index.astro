---
import Layout from '../layouts/Layout.astro';

const codeExample = `import { Breadcrumb } from '@breadcrumb/sdk'

const bc = new Breadcrumb({ apiKey: process.env.KEY })

const result = await bc.trace('chat-response', async (t) => {
  return t.span('llm-call', () => llm.complete(prompt))
})`
---

<Layout>
  <main>
    <!-- ── HERO ─────────────────────────────────────────── -->
    <section class="pt-20 pb-0">
      <div class="max-w-[1000px] mx-auto px-6">

        <!-- Heading block -->
        <div class="mb-16">

          <!-- Logo -->
          <a href="/" class="block mb-8">
            <svg width="54" height="54" viewBox="0 0 278 277" fill="none">
              <path d="M198.033 0.727C240.224 -5.344 278 27.386 278 70.011c0 17.711-6.668 34.277-18 46.857v86.356c-.167-.001-.333-.003-.5-.003-40.041 0-72.5 32.459-72.5 72.5 0 .167.002.334.003.5H53c-18.778 0-34-15.222-34-34V117.955C7.062 105.25 0 88.237 0 70.011 0 27.386 37.776-5.344 79.967.727l47.639 6.854c7.557 1.088 15.231 1.088 22.788 0l47.639-6.854z" fill="currentColor"/>
            </svg>
          </a>

          <h1 class="font-display text-[clamp(36px,5vw,62px)] font-semibold text-balance leading-[1.06] tracking-[-0.03em] text-fg mb-5">
            Simple, open source<br />LLM tracing with breadcrumb
          </h1>

          <p class="text-[15px] leading-[1.7] text-fg-2 max-w-[440px] mb-8">
            Log every prompt, completion, token count, latency, and cost.
            Self-hostable and MIT licensed — integrates in minutes.
          </p>

          <a
            href="/early-access"
            class="inline-flex items-center gap-3 px-5 py-3 bg-fg text-white text-[13px] font-semibold hover:opacity-80 transition-opacity font-display"
          >
            Get early access
            <span>→</span>
          </a>

        </div>

        <!-- ── Trace visualization ────────────────────── -->
        <div class="border border-border bg-white">

          <!-- Header bar -->
          <div class="flex items-center justify-between px-6 py-3 border-b border-border">
            <div class="flex items-center gap-2">
              <span class="relative flex h-[6px] w-[6px]">
                <span class="live-ping absolute inset-0 rounded-full" style="background:#22c08b;opacity:0.4"></span>
                <span class="relative rounded-full h-[6px] w-[6px]" style="background:#22c08b"></span>
              </span>
              <span class="font-mono text-[10px] text-fg-3 tracking-widest uppercase">traces — my-project</span>
            </div>
            <div class="flex items-center gap-4">
              <span class="font-mono text-[10px] text-fg-3">live</span>
              <div class="flex gap-[5px]">
                <span class="block w-[6px] h-[6px]" style="background:#fbbf24"></span>
                <span class="block w-[6px] h-[6px]" style="background:#34d399"></span>
                <span class="block w-[6px] h-[6px]" style="background:#a78bfa"></span>
                <span class="block w-[6px] h-[6px]" style="background:#f472b6"></span>
              </div>
            </div>
          </div>

          <!-- Timeline body -->
          <div class="px-6 pt-5 pb-7">

            <!-- Time axis -->
            <div class="flex justify-between mb-[10px]">
              {['0', '250ms', '500ms', '750ms', '1s+'].map(t => (
                <span class="font-mono text-[9px] text-fg-3" style="opacity:0.4">{t}</span>
              ))}
            </div>

            <!-- Grid + rows -->
            <div class="relative">

              <!-- Vertical grid lines -->
              <div class="absolute inset-0 flex pointer-events-none" aria-hidden="true">
                <div class="w-1/4 border-r border-border h-full"></div>
                <div class="w-1/4 border-r border-border h-full"></div>
                <div class="w-1/4 border-r border-border h-full"></div>
                <div class="w-1/4 h-full"></div>
              </div>

              <!-- Rows (populated by JS) -->
              <div id="tl-rows" class="flex flex-col gap-[13px] relative"></div>

            </div>
          </div>

        </div>
        <!-- end visualization -->

      </div>
    </section>

    <!-- ── BENTO GRID ─────────────────────────────────────── -->
    <section class="mt-16 pb-24">
      <div class="max-w-[1000px] mx-auto px-6">

        <div class="grid grid-cols-3 gap-[1px] bg-border border border-border">

          <!-- 01 — Full trace visibility (2/3 width) -->
          <div class="col-span-2 bg-white p-8">
            <span class="font-mono text-[10px] text-fg-3 tracking-widest uppercase block mb-7">01 — visibility</span>
            <h3 class="font-display text-[19px] font-semibold text-fg tracking-tight leading-snug mb-3">
              Full trace visibility
            </h3>
            <p class="text-[13px] leading-[1.75] text-fg-2 mb-7 max-w-[300px]">
              Every LLM call gets logged — prompt, completion, token count,
              latency, and cost. Nothing slips through the cracks.
            </p>
            <div class="flex flex-wrap gap-1.5">
              {['prompts', 'completions', 'token counts', 'latency', 'cost'].map(tag => (
                <span class="font-mono text-[10px] px-2 py-1 border border-border text-fg-3">{tag}</span>
              ))}
            </div>
          </div>

          <!-- Avg cost metric (1/3 width) -->
          <div class="bg-white p-8 flex flex-col justify-between">
            <span class="font-mono text-[10px] text-fg-3 tracking-widest uppercase">avg. cost / trace</span>
            <div>
              <div class="font-mono text-[38px] font-light text-fg leading-none tracking-tight mb-1.5">$0.0024</div>
              <div class="font-mono text-[10px] text-fg-3">placeholder metric</div>
            </div>
          </div>

          <!-- Open source (1/3 width) -->
          <div class="bg-white p-8 flex flex-col justify-between">
            <span class="font-mono text-[10px] text-fg-3 tracking-widest uppercase">license</span>
            <div>
              <div class="font-display text-[34px] font-semibold text-fg leading-none mb-1">MIT</div>
              <div class="text-[13px] text-fg-2 mb-5">Open source, always.</div>
              <a href="#" class="font-mono text-[10px] text-fg-3 hover:text-fg transition-colors">
                ★ — github.com/breadcrumb
              </a>
            </div>
          </div>

          <!-- 02 — Debug without guessing (2/3 width) -->
          <div class="col-span-2 bg-white p-8">
            <span class="font-mono text-[10px] text-fg-3 tracking-widest uppercase block mb-7">02 — debugging</span>
            <h3 class="font-display text-[19px] font-semibold text-fg tracking-tight leading-snug mb-3">
              Debug without guessing
            </h3>
            <p class="text-[13px] leading-[1.75] text-fg-2 mb-7 max-w-[300px]">
              Trace any bad output back to the exact prompt that caused it. No more adding
              <code class="font-mono text-[11px] bg-surface px-1 py-0.5">console.log</code> to your LLM calls.
            </p>
            <div class="flex items-center gap-2.5">
              <div class="flex items-center gap-1.5">
                <span class="w-[6px] h-[6px] rounded-full bg-[#22c08b]"></span>
                <span class="font-mono text-[10px] text-fg-3">user input</span>
              </div>
              <span class="font-mono text-[10px] text-fg-3">→</span>
              <div class="flex items-center gap-1.5">
                <span class="w-[6px] h-[6px] rounded-full bg-[#fbbf24]"></span>
                <span class="font-mono text-[10px] text-fg-3">llm-call</span>
              </div>
              <span class="font-mono text-[10px] text-fg-3">→</span>
              <div class="flex items-center gap-1.5">
                <span class="w-[6px] h-[6px] rounded-full bg-[#f87171]"></span>
                <span class="font-mono text-[10px] text-fg-3">bad output ✕</span>
              </div>
            </div>
          </div>

          <!-- SDK code snippet (2/3 width) -->
          <div class="col-span-2 bg-surface p-8">
            <span class="font-mono text-[10px] text-fg-3 tracking-widest uppercase block mb-5">sdk</span>
            <pre class="font-mono text-[11.5px] text-fg leading-[1.9] overflow-x-auto"><code set:text={codeExample}></code></pre>
          </div>

          <!-- CTA (1/3 width) -->
          <div class="bg-white p-8 flex flex-col justify-between">
            <div>
              <span class="font-mono text-[10px] text-fg-3 tracking-widest uppercase block mb-5">get access</span>
              <p class="font-display text-[15px] font-semibold text-fg leading-snug mb-2.5">
                Ready to see what's happening?
              </p>
              <p class="text-[12px] text-fg-2 leading-[1.7]">
                Join the waitlist. We'll reach out when it's ready.
              </p>
            </div>
            <a
              href="/early-access"
              class="inline-flex items-center justify-between w-full px-4 py-3 bg-fg text-white text-[12px] font-semibold hover:opacity-80 transition-opacity font-display mt-6"
            >
              Get early access
              <span>→</span>
            </a>
          </div>

        </div>

      </div>
    </section>
  </main>

  <!-- ── FOOTER ─────────────────────────────────────────── -->
  <footer class="border-t border-border py-6">
    <div class="max-w-[1000px] mx-auto px-6 flex items-center justify-between">
      <a href="/" class="flex items-center gap-2 font-display text-[13px] font-medium text-[#bbb]">
        <svg width="14" height="14" viewBox="0 0 278 277" fill="none">
          <path d="M198.033 0.727C240.224 -5.344 278 27.386 278 70.011c0 17.711-6.668 34.277-18 46.857v86.356c-.167-.001-.333-.003-.5-.003-40.041 0-72.5 32.459-72.5 72.5 0 .167.002.334.003.5H53c-18.778 0-34-15.222-34-34V117.955C7.062 105.25 0 88.237 0 70.011 0 27.386 37.776-5.344 79.967.727l47.639 6.854c7.557 1.088 15.231 1.088 22.788 0l47.639-6.854z" fill="currentColor"/>
        </svg>
        breadcrumb
      </a>
      <p class="text-xs text-[#ccc]">&copy; 2026 Breadcrumb</p>
    </div>
  </footer>

<style>
  .live-ping {
    animation: livePing 2s cubic-bezier(0, 0, 0.2, 1) infinite;
  }
  @keyframes livePing {
    75%, 100% { transform: scale(2.8); opacity: 0; }
  }
</style>

<script>
  // ── Abstract timeline animation ───────────────────────────────

  type BlockColor = 'amber' | 'teal' | 'violet' | 'pink';
  type Block = [BlockColor, number, number, number];

  const COLORS: Record<BlockColor, string> = {
    amber:  '#fbbf24',
    teal:   '#34d399',
    violet: '#a78bfa',
    pink:   '#f472b6',
  };

  const SEQS: Block[][] = [
    [['teal',   0, 13, 240], ['amber', 16, 81, 840]],
    [['amber',  0, 19, 340], ['teal', 22,  7, 110], ['teal', 31, 5, 80], ['amber', 38, 59, 720]],
    [['amber',  2, 94, 400]],
    [['violet', 0, 45, 440], ['pink', 49, 48, 500]],
    [['teal',   0,  4,  60], ['amber',  7, 90, 980]],
    [['teal',   0,  9, 150], ['amber', 12, 85, 860]],
    [['violet', 0, 14, 260], ['teal', 17,  6, 100], ['teal', 25, 6, 100], ['amber', 33, 64, 760]],
  ];

  const rowsEl = document.getElementById('tl-rows')!;
  const ROW_COUNT = 5;

  const rowContainers: HTMLElement[] = [];
  for (let i = 0; i < ROW_COUNT; i++) {
    const row = document.createElement('div');
    row.style.cssText = 'position:relative;height:28px;';

    const track = document.createElement('div');
    track.style.cssText = 'position:absolute;inset:0;background:#f0f0f0;border-radius:0;';
    row.appendChild(track);

    rowsEl.appendChild(row);
    rowContainers.push(row);
  }

  const raf2 = () => new Promise<void>(r => requestAnimationFrame(() => requestAnimationFrame(() => r())));
  const sleep = (ms: number) => new Promise<void>(r => setTimeout(r, ms));

  async function animateRow(row: HTMLElement, startIdx: number) {
    let idx = startIdx;

    while (true) {
      const seq = SEQS[idx % SEQS.length];
      idx++;

      const blockEls: HTMLElement[] = [];

      for (const [color, startPct, widthPct, growMs] of seq) {
        const block = document.createElement('div');
        block.style.cssText = `
          position: absolute;
          top: 3px; bottom: 3px;
          left: ${startPct}%;
          width: ${widthPct}%;
          background: ${COLORS[color]};
          border-radius: 0;
          transform: scaleX(0);
          transform-origin: left center;
          will-change: transform;
        `;
        row.appendChild(block);
        blockEls.push(block);

        await raf2();
        block.style.transition = `transform ${growMs}ms cubic-bezier(0.2, 0, 0.05, 1)`;
        block.style.transform = 'scaleX(1)';
        await sleep(growMs + 20);
      }

      await sleep(1600);

      blockEls.forEach(b => {
        b.style.transition = 'opacity 0.32s ease';
        b.style.opacity = '0';
      });
      await sleep(380);

      blockEls.forEach(b => b.remove());
      await sleep(200);
    }
  }

  rowContainers.forEach((row, i) => {
    setTimeout(() => animateRow(row, i), i * 1350);
  });
</script>
</Layout>
