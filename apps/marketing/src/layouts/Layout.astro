---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Open Source LLM Tracing & Observability | Breadcrumb',
  description = 'Breadcrumb is an open source, self-hosted LLM observability tool for TypeScript. Track every prompt, completion, token count, latency, and cost. Deploy in one click.',
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#121213" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalUrl.href} />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="https://breadcrumb.sh/og.png" />
    <meta property="og:url" content={canonicalUrl.href} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Breadcrumb" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://breadcrumb.sh/og.png" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Geist:wght@100..900&family=Geist+Mono:wght@100..900&display=swap" rel="stylesheet" />
    <script defer data-domain="breadcrumb.sh" src="https://nudge-events.up.railway.app/js/script.js"></script>
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "Organization",
          "name": "Breadcrumb",
          "url": "https://breadcrumb.sh",
          "logo": "https://breadcrumb.sh/favicon.svg",
          "sameAs": [
            "https://github.com/joshuaKnauber/breadcrumb",
            "https://x.com/joshuaKnauber"
          ]
        },
        {
          "@type": "SoftwareApplication",
          "name": "Breadcrumb",
          "applicationCategory": "DeveloperApplication",
          "operatingSystem": "Any",
          "description": "Open source, self-hosted LLM observability tool for TypeScript. Track prompts, completions, token counts, latency, and cost.",
          "url": "https://breadcrumb.sh",
          "offers": {
            "@type": "Offer",
            "price": "0",
            "priceCurrency": "USD"
          },
          "programmingLanguage": "TypeScript",
          "license": "https://github.com/joshuaKnauber/breadcrumb/blob/main/LICENSE"
        }
      ]
    })} />
  </head>
  <body>
    <slot />
  </body>
</html>
