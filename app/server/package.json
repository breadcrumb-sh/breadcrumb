    "drizzle-orm": "^0.45.1",
    "hono": "^4",
    "hono-rate-limiter": "^0.4.2",
    "jose": "^6.2.2",
    "picomatch": "^4.0.4",
    "pino": "^10.3.1",
    "postgres": "^3",
    "posthog-node": "^5.28.2",
    "superjson": "^2",
    "zod": "^3.25.76"
