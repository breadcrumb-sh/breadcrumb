  },
  "peerDependencies": {
    "@breadcrumb/sdk": "*"
  },
  "devDependencies": {
    "@breadcrumb/sdk": "*",
    "tsdown": "^0.9",
    "typescript": "^5.7",
    "vitest": "^3"
  }
}
