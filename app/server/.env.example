# Better Auth
BETTER_AUTH_SECRET=change-me-to-a-long-random-string
APP_BASE_URL=http://localhost:3000

# PostgreSQL
DATABASE_URL=postgres://postgres:postgres@localhost:5432/breadcrumb

# ClickHouse
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_DB=breadcrumb
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_READONLY_USER=
CLICKHOUSE_READONLY_PASSWORD=
CLICKHOUSE_SANDBOX_USER=breadcrumb_sandbox
CLICKHOUSE_SANDBOX_PASSWORD=breadcrumb_sandbox_local

# Encryption (generate with: openssl rand -hex 32)
ENCRYPTION_KEY=

# Server
PORT=3100
NODE_ENV=development

# Open signup: comma-separated org IDs that new users auto-join as viewer
ALLOW_OPEN_SIGNUP=
# Set to false to disable org creation (orgs must be seeded in DB)
ALLOW_ORG_CREATION=true
# Demo
IS_BREADCRUMB_DEMO=false

# Telemetry (set to true to disable anonymous usage telemetry)
DISABLE_TELEMETRY=false

# Evals (npm run eval)
OPENROUTER_API_KEY=
EVAL_MODEL=anthropic/claude-haiku-4.5

# GitHub App (optional — leave unset to disable the GitHub integration)
# Create an app at https://github.com/settings/apps/new (or in your org settings).
# Permissions: Contents=Read, Metadata=Read, Issues=Read+Write, Pull requests=Read+Write.
# For the private key, paste the PEM contents. Multi-line values should use \n escapes:
#   GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n"
GITHUB_APP_ID=
GITHUB_APP_SLUG=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
GITHUB_APP_WEBHOOK_SECRET=
# Override for GitHub Enterprise Server (defaults to https://api.github.com)
GITHUB_API_URL=https://api.github.com
